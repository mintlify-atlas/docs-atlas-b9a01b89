  "keyFeatures": [
    "Multi-vendor role-based access (vendor and admin roles)",
    "Real-time order management with status filtering",
    "Product synchronization between Bsale POS and Shopify",
    "MercadoPago payment processing integration",
    "Uber Direct delivery quoting and tracking",
    "Firebase Authentication with Google OAuth support",
    "Bsale OAuth integration for POS token management",
    "Cloud Functions backend (Express on Firebase Functions)"
  ],
